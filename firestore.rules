rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ======= 🔧 الدوال المساعدة =======
    function isSignedIn() {
      return request.auth != null;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isUserActive() {
      return isSignedIn() && 
      userExists() && 
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isActive', false) == true;
    }

    function isAdmin() {
      return isSignedIn() && 
      userExists() && 
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }

    function userOwnsDocument() {
      return isSignedIn() && 
      resource != null && 
      resource.data.userId == request.auth.uid;
    }

    function userHasCompany(companyId) {
      return isSignedIn() && 
      userExists() && 
      get(/databases/$(database)/documents/users/$(request.auth.uid))
      .data.get('companyIds', []).hasAny([companyId]);
    }

    function userHasSupplier(supplierId) {
      return isSignedIn() && 
      userExists() && 
      get(/databases/$(database)/documents/users/$(request.auth.uid))
      .data.get('supplierIds', []).hasAny([supplierId]);
    }

    function userHasFactory(factoryId) {
      return isSignedIn() && 
      userExists() && 
      get(/databases/$(database)/documents/users/$(request.auth.uid))
      .data.get('factoryIds', []).hasAny([factoryId]);
    }

    function userHasAnyCompany(companyIds) {
      return isSignedIn() &&
      userExists() &&
      companyIds.hasAny(
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyIds
      );
    }

    function userHasAnyCompanyInFactory(factoryId) {
      let factoryPath = /databases/$(database)/documents/factories/$(factoryId);
      return exists(factoryPath) &&
      userHasAnyCompany(get(factoryPath).data.companyIds);
    }


    function userHasCompanyFromProduct(productId) {
      let productPath = /databases/$(database)/documents/finished_products/$(productId);
      return isSignedIn() &&
      userExists() &&
      exists(productPath) &&
      userHasCompany(get(productPath).data.companyId);
    }


    // ======= 👥 المستخدمين =======
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && !exists(/databases/$(database)/documents/users/$(userId));

      allow update: if isSignedIn() &&
      (request.auth.uid == userId || isAdmin()) &&
      (
      (request.auth.uid == userId &&
      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deviceIds', 'lastUpdated']))
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ======= 🔐 التراخيص =======
    match /licenses/{licenseId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/licenses/$(licenseId)).data.userId == request.auth.uid
      );

      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          get(/databases/$(database)/documents/licenses/$(licenseId)).data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['devices', 'deviceIds', 'lastUpdated'])
        )
      );



      allow create, delete: if isAdmin();

      allow list: if isSignedIn() && (isAdmin() || userOwnsDocument());
    }

    // ======= 📋 طلبات الأجهزة =======
    match /device_requests/{requestId} {
      allow read: if isSignedIn() && 
      (request.auth.uid == resource.data.userId || isAdmin());

      allow create: if isSignedIn() && 
      request.auth.uid == request.resource.data.userId;

      allow update: if isSignedIn() && isAdmin();

      allow delete: if isSignedIn() && 
      (request.auth.uid == resource.data.userId || isAdmin());

      allow list: if isSignedIn() && isAdmin();
    }

    // ======= 📝 طلبات الترخيص =======
    match /license_requests/{requestId} {
      allow read: if isSignedIn() && 
      (isAdmin() || resource.data.userId == request.auth.uid);

      allow create: if isSignedIn() && 
      request.auth.uid == request.resource.data.userId;

      allow update, delete: if isSignedIn() && isAdmin();

      allow list: if isSignedIn() && isAdmin();
    }

    // ======= 🔔 الإشعارات =======
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() && 
      (isAdmin() || request.resource.data.userId == request.auth.uid);

      allow update, delete: if isSignedIn() && isAdmin();
    }

    // ======= 🏢 الشركات =======
    match /companies/{companyId} {
      allow create: if isSignedIn() && isUserActive();

      allow read, update, delete: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(companyId);

      allow list: if isSignedIn() && isUserActive();
    }

    // ======= 🏭 المصانع =======
    match /factories/{factoryId} {
      allow create: if isSignedIn() &&
      isUserActive() &&
      request.resource.data.userId == request.auth.uid;

      allow get, read: if isSignedIn() &&
      (
      resource.data.userId == request.auth.uid ||
      resource.data.companyIds.hasAny(
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyIds
      )
      );

      allow update, delete: if isSignedIn() &&
      isUserActive() &&
      resource.data.userId == request.auth.uid;

      allow list: if isSignedIn() && isUserActive();
    }

    // ======= 🛒 الموردين =======
    match /vendors/{supplierId} {
      allow create: if isSignedIn() && isUserActive();

      allow read, update, delete: if isSignedIn() &&
      isUserActive() &&
      (resource.data.userId == request.auth.uid || userHasSupplier(supplierId));

      allow list: if isSignedIn() && isUserActive();
    }

    // ======= 📦 الأصناف =======
    match /items/{itemId} {
      allow create: if isSignedIn() &&
      isUserActive() &&
      request.resource.data.userId == request.auth.uid;

      allow read, update, delete: if isSignedIn() &&
      isUserActive() &&
      resource.data.userId == request.auth.uid;

      allow list: if isSignedIn() && isUserActive();
    }

    // ======= 🛍️ أوامر الشراء =======
    match /purchase_orders/{orderId} {
      allow create, update: if isSignedIn() && isUserActive() && userHasCompany(request.resource.data.companyId);
      allow read: if isSignedIn() && isUserActive(); // يمكنك إضافة شرط userHasCompany(resource.data.companyId) إذا أردت
      allow delete: if isSignedIn() 
        && isUserActive() 
        && userHasCompany(resource.data.companyId)
        && (resource.data.isDelivered != true);
    }


    // ======= 🏭 المنتجات التامة =======
    match /finished_products/{prodId} {
      allow create: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(request.resource.data.companyId);

      allow read, update, delete: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(resource.data.companyId);

      allow list: if isSignedIn() && isUserActive();
    }

    // ======= ⚙️ أوامر التصنيع =======
    match /manufacturing_orders/{orderId} {
      allow create: if isSignedIn();

      allow read, update, delete: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(resource.data.companyId);

      allow list: if isSignedIn() && isUserActive();
    }

    // ======= 📊 المخزون في المصانع =======
    match /factories/{factoryId}/inventory/{productId} {
      allow create, read, update: if isSignedIn() && isUserActive() && userHasAnyCompanyInFactory(factoryId);
      allow read: if isSignedIn() && isUserActive() && userHasFactory(factoryId);
    }


    // ======= 📈 الحركات المخزنية =======
    match /companies/{companyId}/stock_movements/{movementId} {
      allow create, read, update, delete: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(companyId);
    }

    // ======= 🧩 مكونات المنتجات =======
    match /finished_products/{productId}/composition/{document} {
      allow create: if isSignedIn() 
        && isUserActive() 
        && exists(/databases/$(database)/documents/finished_products/$(productId)) &&
      userHasCompany(get(/databases/$(database)/documents/finished_products/$(productId)).data.companyId);

      allow read: if isSignedIn() 
        && isUserActive() 
        && exists(/databases/$(database)/documents/finished_products/$(productId)) &&
      userHasCompany(get(/databases/$(database)/documents/finished_products/$(productId)).data.companyId);

      allow update, delete: if isSignedIn() 
        && isUserActive() 
        && exists(/databases/$(database)/documents/finished_products/$(productId)) &&
      userHasCompany(get(/databases/$(database)/documents/finished_products/$(productId)).data.companyId);
    }


    // ======= 📦 مخزن المنتجات التامة لكل شركة =======
    match /companies/{companyId}/finished_products_inventory/{productId} {
      allow create: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(companyId) &&
      request.resource.data.userId == request.auth.uid;

      allow read, update, delete, list: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(companyId);
    }

    // ✅ تفاصيل التشغيل
    match /companies/{companyId}/finished_products_inventory/{productId}/batches/{batchId} {
      allow read, create, update, delete, list: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(companyId);
    }

    // ✅ مواقع التخزين
    match /companies/{companyId}/finished_products_inventory/{productId}/storage_locations/{locationId} {
      allow read, create, update, delete, list: if isSignedIn() &&
      isUserActive() &&
      userHasCompany(companyId);
    }
  }
}



// 1. run : #  firebase emulators:exec "npm run test:rules"
// 2. run : #  firebase deploy --only firestore:rules